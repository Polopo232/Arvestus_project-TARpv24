<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:Arvestus_project_TARpv24.Views"
       xmlns:loc="clr-namespace:Arvestus_project_TARpv24.Localization"
       x:Class="Arvestus_project_TARpv24.AppShell">

    <TabBar>
        <Tab Title="{loc:Translate MenuTab}">
            <ShellContent ContentTemplate="{DataTemplate views:MenuPage}"
                          Route="MenuPage" />
        </Tab>

        <Tab Title="{loc:Translate DailyMenuTab}">
            <ShellContent ContentTemplate="{DataTemplate views:DailyMenuPage}"
                          Route="DailyMenuPage" />
        </Tab>

        <Tab Title="{loc:Translate ProfileTab}">
            <ShellContent ContentTemplate="{DataTemplate views:ProfilePage}"
                          Route="ProfilePage" />
        </Tab>

        <Tab Title="{loc:Translate SettingsTab}">
            <ShellContent ContentTemplate="{DataTemplate views:SettingsPage}"
                          Route="SettingsPage" />
        </Tab>
    </TabBar>

</Shell>