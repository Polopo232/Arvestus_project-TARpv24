<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Arvestus_project_TARpv24.ViewModels"
             xmlns:loc="clr-namespace:Arvestus_project_TARpv24.Localization"
             x:Class="Arvestus_project_TARpv24.Views.AddDishPage"
             x:DataType="vm:AddDishViewModel"
             Title="{loc:Translate AddDishTitle}">

    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="15">

            <Label Text="{loc:Translate DishTitle}" FontSize="20" FontAttributes="Bold" Margin="0,0,0,10" />

            <Entry Placeholder="{loc:Translate DishNamePlaceholder}" Text="{Binding Name}" />
            <Entry Placeholder="{loc:Translate CategoryPlaceholder}" Text="{Binding Category}" />
            <Editor Placeholder="{loc:Translate DescriptionPlaceholder}" HeightRequest="100" Text="{Binding Description}" />
            <Entry Placeholder="{loc:Translate AllergensPlaceholder}" Text="{Binding Allergens}" />

            <Button Text="{loc:Translate AddPhoto}"
                    Command="{Binding PickPhotoCommand}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                    TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}" />

            <Border IsVisible="{Binding HasImage}"
                    StrokeShape="RoundRectangle 10"
                    StrokeThickness="0"
                    HeightRequest="180"
                    Margin="0,5,0,0">
                <Image Source="{Binding ImagePath}" Aspect="AspectFill" />
            </Border>

            <Button Text="{loc:Translate SaveDish}"
                    Command="{Binding SaveDishCommand}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                    TextColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource PrimaryDarkText}}"
                    Margin="0,10,0,0" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>