<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Arvestus_project_TARpv24.ViewModels"
             xmlns:models="clr-namespace:Arvestus_project_TARpv24.Models"
             xmlns:loc="clr-namespace:Arvestus_project_TARpv24.Localization"
             x:Class="Arvestus_project_TARpv24.Views.DailyMenuPage"
             x:DataType="vm:DailyMenuViewModel"
             Title="{loc:Translate DailyMenuTitle}">

    <Grid RowDefinitions="Auto, *, Auto" Padding="20" RowSpacing="15">

        <HorizontalStackLayout Grid.Row="0" Spacing="10" VerticalOptions="Center">
            <DatePicker Date="{Binding SelectedDate}" Format="dd.MM.yyyy" />
            <Button Text="{loc:Translate ModeButton}"
                    Command="{Binding ToggleSelectionModeCommand}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Secondary}, Dark={StaticResource PrimaryDark}}"
                    TextColor="{AppThemeBinding Light={StaticResource SecondaryDarkText}, Dark={StaticResource PrimaryDarkText}}"
                    IsVisible="{Binding Session.IsAdmin}" />
        </HorizontalStackLayout>

        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding DailyDishes}"
                        EmptyView="{loc:Translate NoDailyMenu}">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="15" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Dish">
                    <Border StrokeShape="RoundRectangle 10"
                            StrokeThickness="1"
                            Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray500}}"
                            BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}"
                            Padding="15">
                        <Border.GestureRecognizers>
                            <!-- Tap to Place / Remove -->
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DailyMenuViewModel}}, Path=RemoveFromDailyCommand}"
                                CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>

                        <VerticalStackLayout Spacing="5">
                            <HorizontalStackLayout Spacing="5">
                                <Label Text="{Binding Name}" FontSize="18" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}" />
                                <Label Text="❌" IsVisible="{Binding Source={RelativeSource AncestorType={x:Type vm:DailyMenuViewModel}}, Path=IsSelectionMode}"
                                       FontSize="16" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <Label Text="{Binding Category}" FontSize="12" FontAttributes="Italic"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}" />
                            <Label Text="{Binding Description}" FontSize="14"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Grid.Row="2"
            Text="{loc:Translate AddSelectedToDaily}"
            Command="{Binding AddSelectedDishToDailyCommand}"
            IsVisible="{Binding Session.IsAdmin}"
            BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
            TextColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource PrimaryDarkText}}" />

    </Grid>
</ContentPage>
