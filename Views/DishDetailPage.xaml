<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Arvestus_project_TARpv24.ViewModels"
             xmlns:models="clr-namespace:Arvestus_project_TARpv24.Models"
             xmlns:loc="clr-namespace:Arvestus_project_TARpv24.Localization"
             x:Class="Arvestus_project_TARpv24.Views.DishDetailPage"
             x:DataType="vm:DishDetailViewModel"
             Title="{loc:Translate DishDetailTitle}">

    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="20">

            <Border StrokeShape="RoundRectangle 10" Padding="15"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}">
                <VerticalStackLayout Spacing="10">
                    <Border IsVisible="{Binding Dish.ImagePath, Converter={StaticResource IsStringNotEmptyConverter}}"
                            StrokeShape="RoundRectangle 10"
                            StrokeThickness="0"
                            HeightRequest="200">
                        <Image Source="{Binding Dish.ImagePath}" Aspect="AspectFill" />
                    </Border>

                    <Label Text="{Binding Dish.Name}" FontSize="24" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}" />

                    <Label Text="{Binding Dish.AverageRating, StringFormat='⭐ {0:F1}'}"
                           FontSize="16" FontAttributes="Bold"
                           IsVisible="{Binding Dish.RatingCount, Converter={StaticResource GreaterThanZeroConverter}}"
                           TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource White}}" />

                    <Label Text="{Binding Dish.Category}" FontSize="14" FontAttributes="Italic"
                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}" />
                    <Label Text="{Binding Dish.Description}" FontSize="16"
                           TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}" />

                    <HorizontalStackLayout Spacing="5" Margin="0,10,0,0">
                        <Label Text="{loc:Translate Allergens}" FontSize="14" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={StaticResource Magenta}, Dark={StaticResource White}}" />
                        <Label Text="{Binding Dish.Allergens}" FontSize="14"
                               TextColor="{AppThemeBinding Light={StaticResource Magenta}, Dark={StaticResource White}}" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Label Text="{loc:Translate RatingLabel}" FontSize="18" FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}" />

            <CollectionView ItemsSource="{Binding Ratings}" EmptyView="{loc:Translate NoRatings}">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Rating">
                        <Border StrokeShape="RoundRectangle 5" Padding="10"
                                Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray500}}"
                                BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}">
                            <VerticalStackLayout Spacing="5">
                                <HorizontalStackLayout Spacing="5">
                                    <Label Text="{loc:Translate ScoreLabel}" FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}" />
                                    <Label Text="{Binding Score}" TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource White}}" FontAttributes="Bold" />
                                    <Label Text="/ 5" TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}" />
                                    <Label Text="|" TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}" />
                                    <Label Text="{Binding Username}" FontSize="12" FontAttributes="Italic"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
                                </HorizontalStackLayout>
                                <Label Text="{Binding Comment}" FontSize="14"
                                       IsVisible="{Binding Comment, Converter={StaticResource IsStringNotEmptyConverter}}"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}" />
                                <Border IsVisible="{Binding ImagePath, Converter={StaticResource IsStringNotEmptyConverter}}"
                                        StrokeShape="RoundRectangle 8"
                                        StrokeThickness="0"
                                        HeightRequest="140"
                                        HorizontalOptions="Start"
                                        Margin="0,5,0,0">
                                    <Image Source="{Binding ImagePath}" Aspect="AspectFill" WidthRequest="200" />
                                </Border>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Border StrokeShape="RoundRectangle 10" Padding="15" IsVisible="{Binding Session.IsLoggedIn}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{loc:Translate AddRating}" FontSize="16" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}" />

                    <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                        <Label Text="{loc:Translate RateLabel}" VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}" />
                        <Stepper Minimum="1" Maximum="5" Value="{Binding NewScore}" />
                        <Label Text="{Binding NewScore}" FontAttributes="Bold" VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}" />
                    </HorizontalStackLayout>

                    <Entry Placeholder="{loc:Translate CommentPlaceholder}" Text="{Binding NewComment}" />

                    <Button Text="{loc:Translate AddPhoto}"
                            Command="{Binding PickPhotoCommand}"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                            TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}" />

                    <Border IsVisible="{Binding HasNewImage}"
                            StrokeShape="RoundRectangle 8"
                            StrokeThickness="0"
                            HeightRequest="140"
                            HorizontalOptions="Start">
                        <Image Source="{Binding NewImagePath}" Aspect="AspectFill" WidthRequest="200" />
                    </Border>

                    <Button Text="{loc:Translate SaveRating}"
                            Command="{Binding AddRatingCommand}"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                            TextColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource PrimaryDarkText}}" />
                </VerticalStackLayout>
            </Border>

            <Border StrokeShape="RoundRectangle 10" Padding="15" IsVisible="{Binding Session.IsLoggedOut}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Secondary}, Dark={StaticResource Gray900}}">
                <Label Text="{loc:Translate LoginRequiredRating}" HorizontalOptions="Center"
                       TextColor="{AppThemeBinding Light={StaticResource SecondaryDarkText}, Dark={StaticResource Gray400}}" />
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>