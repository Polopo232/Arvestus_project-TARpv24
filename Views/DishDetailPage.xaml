<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Arvestus_project_TARpv24.ViewModels"
             xmlns:models="clr-namespace:Arvestus_project_TARpv24.Models"
             x:Class="Arvestus_project_TARpv24.Views.DishDetailPage"
             x:DataType="vm:DishDetailViewModel"
             Title="Toidu andmed">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Label Text="{Binding SelectedDish.Name}" FontSize="24" FontAttributes="Bold" />
            <Label Text="{Binding SelectedDish.Category}" FontSize="14" FontAttributes="Italic" TextColor="Gray" />
            <Label Text="{Binding SelectedDish.Description}" FontSize="16" />

            <HorizontalStackLayout Spacing="5">
                <Label Text="Allergeenid:" FontAttributes="Bold" TextColor="Red" />
                <Label Text="{Binding SelectedDish.Allergens}" TextColor="Red" />
            </HorizontalStackLayout>

            <BoxView HeightRequest="1" Color="#E0E0E0" />

            <Label Text="Lisa arvustus" FontSize="18" FontAttributes="Bold" />

            <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                <Label Text="Hinne (1-5):" VerticalOptions="Center" />
                <Stepper Minimum="1" Maximum="5" Increment="1" Value="{Binding NewScore}" />
                <Label Text="{Binding NewScore}" FontAttributes="Bold" VerticalOptions="Center" />
            </HorizontalStackLayout>

            <Entry Placeholder="Kirjutage oma arvustus siia..." Text="{Binding NewComment}" />

            <Button Text="Saada arvustus" Command="{Binding AddRatingCommand}" BackgroundColor="#512BD4" TextColor="White" />

            <BoxView HeightRequest="1" Color="#E0E0E0" />

            <Label Text="Kasutajate arvustused" FontSize="18" FontAttributes="Bold" />

            <CollectionView ItemsSource="{Binding Ratings}" EmptyView="Arvustused puuduvad.">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Rating">
                        <Border StrokeShape="RoundRectangle 5" StrokeThickness="1" Stroke="#CCCCCC" Padding="10">
                            <VerticalStackLayout Spacing="5">
                                <HorizontalStackLayout Spacing="5">
                                    <Label Text="Hinne:" FontAttributes="Bold" />
                                    <Label Text="{Binding Score}" TextColor="Orange" FontAttributes="Bold" />
                                </HorizontalStackLayout>
                                <Label Text="{Binding Comment}" FontSize="14" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>