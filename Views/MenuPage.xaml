<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Arvestus_project_TARpv24.ViewModels"
             xmlns:models="clr-namespace:Arvestus_project_TARpv24.Models"
             x:Class="Arvestus_project_TARpv24.Views.MenuPage"
             x:DataType="vm:MenuViewModel"
             Title="Lunchbox Menüü">

    <Grid RowDefinitions="Auto, *, Auto" Padding="20" RowSpacing="10">

        <SearchBar Grid.Row="0" 
                   Placeholder="Otsi toitu või kategooriat..." 
                   Text="{Binding SearchText}" />

        <CollectionView Grid.Row="1" 
                        ItemsSource="{Binding Dishes}"
                        EmptyView="Toite ei leitud.">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="15" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Dish">
                    <Border StrokeShape="RoundRectangle 10"
                            StrokeThickness="1"
                            Stroke="#E0E0E0"
                            Padding="15">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer 
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MenuViewModel}}, Path=SelectDishCommand}"
                                CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>

                        <VerticalStackLayout Spacing="5">
                            <Label Text="{Binding Name}" 
                                   FontSize="18" 
                                   FontAttributes="Bold" />

                            <Label Text="{Binding Category}" 
                                   FontSize="12" 
                                   FontAttributes="Italic"
                                   TextColor="Gray" />

                            <Label Text="{Binding Description}" 
                                   FontSize="14" />

                            <HorizontalStackLayout Spacing="5" Margin="0,5,0,0">
                                <Label Text="Allergeenid:" FontSize="12" FontAttributes="Bold" TextColor="Red" />
                                <Label Text="{Binding Allergens}" FontSize="12" TextColor="Red" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Grid.Row="2"
            Text="Lisa testtoit"
            Command="{Binding AddTestDishCommand}"
            IsVisible="{Binding Session.IsAdmin}"
            BackgroundColor="#512BD4"
            TextColor="White" />

    </Grid>
</ContentPage>