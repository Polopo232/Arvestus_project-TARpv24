<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Arvestus_project_TARpv24.ViewModels"
             xmlns:models="clr-namespace:Arvestus_project_TARpv24.Models"
             xmlns:loc="clr-namespace:Arvestus_project_TARpv24.Localization"
             x:Class="Arvestus_project_TARpv24.Views.MenuPage"
             x:DataType="vm:MenuViewModel"
             Title="{loc:Translate MenuTab}">

    <Grid RowDefinitions="Auto, *, Auto" Padding="20" RowSpacing="10">

        <SearchBar Grid.Row="0"
                   Placeholder="{loc:Translate SearchPlaceholder}"
                   Text="{Binding SearchText}" />

        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Dishes}"
                        EmptyView="{loc:Translate NoDishesFound}">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="15" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Dish">
                    <Border StrokeShape="RoundRectangle 10"
                            StrokeThickness="1"
                            Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray500}}"
                            BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}"
                            Padding="15">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MenuViewModel}}, Path=SelectDishCommand}"
                                CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>

                        <VerticalStackLayout Spacing="5">
                            <HorizontalStackLayout Spacing="10">
                                <Label Text="{Binding Name}"
                                       FontSize="18"
                                       FontAttributes="Bold" />
                                <Label Text="{Binding AverageRating, StringFormat='⭐ {0:F1} ({1})'}"
                                       FontSize="14"
                                       TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource White}}"
                                       IsVisible="{Binding RatingCount, Converter={StaticResource GreaterThanZeroConverter}}"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>

                            <Label Text="{Binding Category}"
                                   FontSize="12"
                                   FontAttributes="Italic"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}" />

                            <Label Text="{Binding Description}"
                                   FontSize="14" />

                            <HorizontalStackLayout Spacing="5" Margin="0,5,0,0">
                                <Label Text="{loc:Translate Allergens}" FontSize="12" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light={StaticResource Magenta}, Dark={StaticResource White}}" />
                                <Label Text="{Binding Allergens}" FontSize="12"
                                       TextColor="{AppThemeBinding Light={StaticResource Magenta}, Dark={StaticResource White}}" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Grid.Row="2"
            Text="{loc:Translate AddDish}"
            Command="{Binding AddDishCommand}"
            IsVisible="{Binding Session.IsAdmin}"
            BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
            TextColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource PrimaryDarkText}}" />

    </Grid>
</ContentPage>
